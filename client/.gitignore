# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# docs site — generated from ../docs (Docusaurus) into public/docs at build time
/public/docs

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# .env.mainnet holds only public NEXT_PUBLIC_* values (network/contract addresses) — safe to commit
!.env.mainnet

# vercel
.vercel

# cloudflare (OpenNext build output + wrangler state; secrets live in .dev.vars)
/.open-next/
/.wrangler/
.dev.vars*

# typescript
*.tsbuildinfo
next-env.d.ts

# bun is optional locally; npm's package-lock.json is authoritative
bun.lock
bun.lockb

# ad-hoc one-off test/drill/debug scripts (e.g. manual E2E trade drills) —
# never meant to be committed; scratch work only
_drill_*
_scratch_*
_tmp_*.mjs
_tmp_*.ts
