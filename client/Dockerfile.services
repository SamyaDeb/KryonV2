FROM node:22-alpine AS base
WORKDIR /app
COPY package*.json ./
RUN npm ci --omit=dev
COPY . .

# Build TypeScript config (needed by tsx at runtime)
RUN npm install tsx --save-dev

# Each service is selected via SERVICE env var
# oracle-keeper | matcher | ws-server | state-indexer | monitor | settlement-reconciler

CMD ["sh", "-c", "npx tsx scripts/${SERVICE}.ts"]
