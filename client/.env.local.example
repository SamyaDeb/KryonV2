# Copy to .env.local and fill in values.
# In Railway production: inject SECRET_* vars via the Railway Secrets UI
# (Variables → add secret) and reference them as ${{secret:VAR_NAME}}.

# ── Database (server-side only — never expose to browser) ─────────────────────
DATABASE_URL=
# Prisma needs a direct (non-pooled) URL for migrations:
DIRECT_URL=

# ── Stellar Network ───────────────────────────────────────────────────────────
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_STELLAR_PASSPHRASE=Test SDF Network ; September 2015
NEXT_PUBLIC_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_ACTIVE_MARKETS=XLM-PERP

# ── Deployed Contract IDs ─────────────────────────────────────────────────────
NEXT_PUBLIC_CONTRACT_GOVERNANCE=
NEXT_PUBLIC_CONTRACT_ORACLE_ADAPTER=
NEXT_PUBLIC_CONTRACT_VAULT=
NEXT_PUBLIC_CONTRACT_ENGINE=
NEXT_PUBLIC_CONTRACT_ORDER_GATEWAY=
NEXT_PUBLIC_CONTRACT_INSURANCE=
NEXT_PUBLIC_CONTRACT_LIQUIDATION=
NEXT_PUBLIC_CONTRACT_RISK=

# ── Asset Contracts ───────────────────────────────────────────────────────────
NEXT_PUBLIC_ASSET_NATIVE_XLM=
NEXT_PUBLIC_ASSET_USDC=
NEXT_PUBLIC_USDC_ISSUER=

# ── API routing ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_INDEXER_URL=http://localhost:3000/api
NEXT_PUBLIC_MATCHER_URL=http://localhost:3000/api

# ── WebSocket / App URLs ──────────────────────────────────────────────────────
# Set NEXT_PUBLIC_WS_URL to the ws-server address to enable live streaming.
# When unset the UI falls back to REST polling automatically.
NEXT_PUBLIC_WS_URL=
NEXT_PUBLIC_APP_URL=

# ── Operator secrets (server-side only, NEVER prefix with NEXT_PUBLIC_) ───────
# Stellar secret keys (S...). ONE ROLE PER KEY — the oracle publisher, matcher
# operator, and liquidator must be three distinct funded accounts. None of them
# may be the contract admin.
# NEVER commit real values here — rotate keys immediately if leaked.
ORACLE_PUBLISHER_SECRET=
MATCHER_OPERATOR_SECRET=
LIQUIDATOR_SECRET=

# ── Rate limiting (Upstash Redis — REQUIRED in production) ───────────────────
# Without these, production API routes fail closed (deny) on rate-limited
# endpoints: the in-memory fallback is per-instance and useless under scale.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ── Settlement reconciler tuning ──────────────────────────────────────────────
# How long (minutes) before an unsigned QUEUED TxJob is expired and rolled back
SETTLEMENT_JOB_MAX_AGE_MINUTES=15

# ── Oracle keeper tuning ──────────────────────────────────────────────────────
# Minimum independent price sources (Binance/Coinbase/Kraken) per publish:
# ORACLE_MIN_SOURCES=2
# Max disagreement between sources before the tick is skipped (bps):
# ORACLE_MAX_SOURCE_DEVIATION_BPS=200
# USDC depeg threshold that halts USDC publication (bps off $1):
# USDC_DEPEG_HALT_BPS=100

# ── Liquidation keeper tuning ─────────────────────────────────────────────────
# LIQUIDATION_INTERVAL_MS=5000
# LIQUIDATION_MAX_ACCOUNTS=500

# ── WebSocket server port (for ws-server.ts standalone process) ───────────────
# WS_PORT=8080
